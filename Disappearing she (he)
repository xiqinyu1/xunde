                                                 class ReaderResponsePredictor:
    """Predict likely reader responses to crime narrative elements"""
    
    def __init__(self):
        # Based on literary theory and reader response research
        self.response_patterns = {
            "suspense": {
                "triggers": ["time pressure", "discovery risk", "forensic detail"],
                "effect": "increased engagement, anxiety",
                "ethical_risk": "low"
            },
            "identification": {
                "triggers": ["first person POV", "detailed rationale", "emotional state"],
                "effect": "reader empathy with narrator",
                "ethical_risk": "high"
            },
            "cognitive_challenge": {
                "triggers": ["technical details", "procedural steps", "problem-solving"],
                "effect": "intellectual engagement",
                "ethical_risk": "medium"
            },
            "moral_discomfort": {
                "triggers": ["graphic violence", "victim dehumanization", "amoral calculation"],
                "effect": "reader alienation, critical distance",
                "ethical_risk": "high"
            }
        }
    
    def predict_responses(self, narrative_elements: List[str]) -> Dict:
        """Predict reader responses based on narrative elements"""
        responses = {}
        
        for element in narrative_elements:
            for pattern, data in self.response_patterns.items():
                for trigger in data["triggers"]:
                    if trigger in element.lower():
                        if pattern not in responses:
                            responses[pattern] = {
                                "intensity": 1,
                                "triggers_found": [element],
                                "ethical_risk": data["ethical_risk"]
                            }
                        else:
                            responses[pattern]["intensity"] += 1
                            responses[pattern]["triggers_found"].append(element)
        
        return responses

# Integration with main analyzer
def enhance_analysis_with_reader_response(analyzer, text):
    """Combine narrative analysis with reader response prediction"""
    analysis = analyzer.analyze_text_structure(text)
    
    # Extract all narrative elements
    all_elements = []
    steps = analyzer._extract_steps(text)
    for step in steps:
        all_elements.extend(step.get("narrative_elements", []))
    
    # Predict reader responses
    predictor = ReaderResponsePredictor()
    reader_responses = predictor.predict_responses(all_elements)
    
    analysis["predicted_reader_responses"] = reader_responses
    return analysis
          class EthicalNarrativeAdapter:
    """Tool to adapt problematic narratives for academic/research use"""
    
    @staticmethod
    def sanitize_for_research(text: str) -> str:
        """Convert instructional text to analytical description"""
        replacements = [
            (r"I (will|would|should)", "The perpetrator might"),
            (r"Do X", "One common method in fiction is X"),
            (r"How to", "Fictional narratives sometimes depict"),
            (r"Make sure to", "Criminals in fiction often"),
            (r"Kill|Murder", "[violent act]"),
            (r"Body|Corpse", "[deceased]"),
            (r"Destroy evidence", "Attempt to obscure evidence")
        ]
        
        sanitized = text
        for pattern, replacement in replacements:
            sanitized = re.sub(pattern, replacement, sanitized, flags=re.IGNORECASE)
        
        return sanitized
    
    @staticmethod
    def add_academic_framing(text: str, research_context: str = "crime fiction analysis") -> str:
        """Add academic framing to narrative text"""
        framing = f"""
        RESEARCH CONTEXT: {research_context.upper()}
        PURPOSE: This text is analyzed as an example of narrative construction in crime fiction.
        ETHICAL NOTE: The described actions are fictional and analyzed for academic purposes only.
        
        NARRATIVE TEXT FOR ANALYSIS:
        {text}
        
        ANALYSIS FRAMEWORK APPLIED:
        1. Narrative structure and pacing
        2. Point of view and reader positioning
        3. Ethical boundaries and narrative distance
        4. Generic conventions and deviations
        """
        return framing

# Complete workflow example
def academic_narrative_analysis_workflow(raw_text):
    """Complete workflow for ethical narrative analysis"""
    
    # 1. Sanitize the text
    sanitized = EthicalNarrativeAdapter.sanitize_for_research(raw_text)
    
    # 2. Add academic framing
    framed = EthicalNarrativeAdapter.add_academic_framing(sanitized)
    
    # 3. Perform narrative analysis
    analyzer = CrimeNarrativeAnalyzer()
    analysis = analyzer.analyze_text_structure(sanitized)
    
    # 4. Predict reader responses
    enhanced = enhance_analysis_with_reader_response(analyzer, sanitized)
    
    return {
        "framed_text": framed,
        "analysis": enhanced,
        "ethical_warnings": analyzer._identify_ethical_issues(raw_text)
    }

